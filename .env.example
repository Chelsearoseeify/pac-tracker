# Turso database (get from: turso db show <name> --url && turso db tokens create <name>)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Frontend URL for CORS (set in production, e.g. https://pac-tracker.vercel.app)
FRONTEND_URL=http://localhost:5173

# Exposed to the frontend build. Leave empty in dev (Vite proxy -> localhost:3000).
VITE_API_URL=
